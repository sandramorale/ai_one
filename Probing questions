<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Lesson Prompt Generator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .dark { background-color: #1a202c; color: white; }
        .dark .bg-white { background-color: #2d3748; color: white; }
        .dark .border-gray-300 { border-color: #4a5568; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen p-4 md:p-8 transition-colors duration-300">

    <div class="max-w-4xl mx-auto bg-white p-6 rounded-xl shadow-lg">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold">Lesson Prompt Generator</h1>
            <div class="flex gap-2">
                <button onclick="toggleTheme()" class="p-2 rounded bg-gray-200 dark:bg-gray-700">Toggle Theme</button>
                <button onclick="window.print()" class="p-2 rounded bg-blue-500 text-white">Print/PDF</button>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <input type="text" id="title" placeholder="Lesson Title" class="p-2 border rounded w-full">
            <input type="text" id="subject" placeholder="Subject" class="p-2 border rounded w-full">
        </div>

        <h2 class="font-semibold mb-3">Select Components:</h2>
        <div id="components" class="grid grid-cols-2 md:grid-cols-3 gap-2 mb-6">
            ['Learning Objectives', 'Key Terms', 'Key Concepts', 'Pre-test', 'Content', 'Analogies', 'Summary', 'Review Quiz', 'ADA Checklist'].forEach(item => {
                const btn = document.createElement('button');
                btn.textContent = item;
                btn.className = "p-2 bg-gray-100 hover:bg-blue-100 rounded border transition";
                btn.onclick = (e) => e.target.classList.toggle('bg-blue-500');
                document.getElementById('components').appendChild(btn);
            });
        </div>

        <select id="platform" class="w-full p-2 border rounded mb-6">
            <option>ChatGPT</option>
            <option>Claude</option>
            <option>Gemini</option>
        </select>

        <button onclick="generatePrompt()" class="w-full py-3 bg-green-600 text-white rounded font-bold hover:bg-green-700">Generate Prompt</button>

        <div id="outputArea" class="mt-8 hidden">
            <h3 class="font-bold mb-2">Generated Prompt:</h3>
            <textarea id="promptResult" class="w-full h-40 p-4 border rounded mb-4" readonly></textarea>
            <button onclick="copyToClipboard()" class="py-2 px-4 bg-gray-800 text-white rounded">Copy to Clipboard</button>
        </div>
    </div>

    <script>
        function toggleTheme() { document.body.classList.toggle('dark'); }
        
        function generatePrompt() {
            const title = document.getElementById('title').value;
            const subject = document.getElementById('subject').value;
            const platform = document.getElementById('platform').value;
            const selected = Array.from(document.querySelectorAll('#components .bg-blue-500')).map(el => el.textContent);
            
            const prompt = `Act as an expert educator. Create a lesson plan for the subject "${subject}" titled "${title}". Please include the following sections: ${selected.join(', ')}. Format the output for ${platform}.`;
            
            document.getElementById('promptResult').value = prompt;
            document.getElementById('outputArea').classList.remove('hidden');
        }

        function copyToClipboard() {
            const copyText = document.getElementById("promptResult");
            copyText.select();
            document.execCommand("copy");
        }
    </script>
</body>
</html>
